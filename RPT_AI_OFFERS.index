<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bitelity · One Time Reserved Price Trades</title>
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <!-- Google Font: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: radial-gradient(ellipse at 30% 20%, #141e33, #0a0f1c);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            padding: 2rem 1.5rem;
        }
        .card {
            max-width: 1340px;
            width: 100%;
            background: rgba(14, 22, 40, 0.8);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-radius: 3.5rem;
            padding: 2.8rem 2.8rem;
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.8), 0 0 0 1px rgba(255, 255, 255, 0.04);
            border: 1px solid rgba(255, 255, 255, 0.02);
            transition: all 0.2s ease;
        }
        .trust-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.8rem 2rem;
            margin-bottom: 1.8rem;
            padding-bottom: 0.9rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        }
        .trust-bar .brand {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            transition: opacity 0.2s;
            text-decoration: none;
        }
        .trust-bar .brand:hover {
            opacity: 0.8;
        }
        .trust-bar .brand .logo-arrows {
            display: flex;
            flex-direction: column;
            align-items: center;
            line-height: 0.8;
            font-size: 1.8rem;
            color: #4a9eff;
            filter: drop-shadow(0 0 10px rgba(74, 158, 255, 0.25));
            margin-right: 0.1rem;
        }
        .trust-bar .brand .logo-arrows i {
            font-size: 1.5rem;
            font-weight: 900;
            text-shadow: 0 0 12px rgba(74, 158, 255, 0.15);
        }
        .trust-bar .brand .logo-arrows i.fa-arrow-up {
            color: #6ab0ff;
            margin-bottom: -0.15rem;
            transform: translateX(-0.15rem);
        }
        .trust-bar .brand .logo-arrows i.fa-arrow-down {
            color: #3a8ae0;
            margin-top: -0.15rem;
            transform: translateX(0.15rem);
        }
        .trust-bar .brand h1 {
            font-size: 2.2rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, #ffffff 20%, #c8d6f0 80%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .trust-actions {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .info-btn {
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid #3f5a7a;
            color: #b8cceb;
            padding: 0.4rem 1.2rem;
            border-radius: 60px;
            font-size: 0.8rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.25s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        .info-btn i {
            color: #f5d36b;
            font-size: 0.9rem;
        }
        .info-btn:hover {
            background: rgba(245, 211, 107, 0.06);
            border-color: #f5d36b;
            color: #f5d36b;
        }
        .trust-badge {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            background: rgba(111, 207, 151, 0.08);
            padding: 0.3rem 1.2rem 0.3rem 0.8rem;
            border-radius: 60px;
            border: 1px solid rgba(111, 207, 151, 0.15);
        }
        .trust-badge i {
            color: #6fcf97;
            font-size: 0.9rem;
        }
        .trust-badge span {
            color: #b0cce5;
            font-size: 0.75rem;
            font-weight: 500;
            letter-spacing: 0.2px;
        }
        .trust-badge .badge-dot {
            width: 6px;
            height: 6px;
            background: #6fcf97;
            border-radius: 50%;
            display: inline-block;
            animation: pulse-dot 2s infinite;
        }
        @keyframes pulse-dot {
            0% {
                opacity: 0.4;
                transform: scale(0.9);
            }
            50% {
                opacity: 1;
                transform: scale(1.2);
            }
            100% {
                opacity: 0.4;
                transform: scale(0.9);
            }
        }
        .sub-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 2.2rem;
        }
        .sub-head h2 {
            font-weight: 400;
            font-size: 1.1rem;
            color: #b8cceb;
            letter-spacing: 0.4px;
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }
        .sub-head h2 i {
            color: #f5d36b;
            font-size: 0.9rem;
        }
        .step-indicators {
            display: flex;
            gap: 1.2rem;
            color: #8196b9;
            font-weight: 500;
            font-size: 0.95rem;
            align-items: center;
        }
        .step-indicators span {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }
        .step-indicators .num {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #f5d36b;
            color: #0b1120;
            width: 28px;
            height: 28px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.85rem;
            box-shadow: 0 0 16px rgba(245, 211, 107, 0.12);
            transition: 0.2s;
        }
        .plans-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.8rem;
            margin: 2.2rem 0 2.5rem;
        }
        .plan {
            background: rgba(10, 18, 34, 0.7);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            border-radius: 2.2rem;
            padding: 2rem 1.6rem 2rem;
            border: 1px solid rgba(255, 255, 255, 0.04);
            box-shadow: 0 15px 30px -10px rgba(0, 0, 0, 0.6);
            transition: transform 0.25s ease, border-color 0.3s, box-shadow 0.3s;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }
        .plan::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 30% 40%, rgba(245, 211, 107, 0.02), transparent 70%);
            pointer-events: none;
        }
        .plan:hover {
            transform: translateY(-8px);
            border-color: rgba(245, 211, 107, 0.2);
            box-shadow: 0 25px 40px -12px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(245, 211, 107, 0.05);
            background: rgba(14, 24, 46, 0.8);
        }
        .plan-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.8rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            padding-bottom: 0.8rem;
        }
        .plan-name {
            font-weight: 600;
            font-size: 1.25rem;
            letter-spacing: 0.2px;
            color: #eef3fc;
        }
        .plan-price {
            font-weight: 700;
            font-size: 1.6rem;
            color: #f5d36b;
            background: rgba(245, 211, 107, 0.07);
            padding: 0.1rem 0.9rem;
            border-radius: 40px;
            border: 1px solid rgba(245, 211, 107, 0.1);
        }
        .plan-ai {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.8rem;
            padding: 0.3rem 0.8rem;
            background: rgba(245, 211, 107, 0.05);
            border-radius: 40px;
            border: 1px solid rgba(245, 211, 107, 0.06);
        }
        .plan-ai i {
            font-size: 1.1rem;
            color: #f5d36b;
        }
        .plan-ai span {
            font-size: 0.8rem;
            color: #b8cceb;
            font-weight: 500;
            letter-spacing: 0.2px;
        }
        .plan-features {
            list-style: none;
            margin: 0.8rem 0 1.8rem;
            flex: 1;
        }
        .plan-features li {
            display: flex;
            align-items: flex-start;
            gap: 0.7rem;
            color: #cfdef5;
            font-size: 0.92rem;
            padding: 0.5rem 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.015);
        }
        .plan-features li i {
            color: #f5d36b;
            font-size: 0.85rem;
            margin-top: 0.2rem;
            min-width: 1.2rem;
        }
        .plan-features li .fa-check {
            color: #6fcf97;
        }
        .btn-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            margin-top: 0.3rem;
        }
        .btn-invest {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            background: linear-gradient(135deg, #f5d36b, #e2b84a);
            border: none;
            padding: 0.85rem 0.5rem;
            border-radius: 60px;
            font-weight: 700;
            font-size: 1rem;
            color: #0b1120;
            transition: all 0.25s;
            cursor: pointer;
            box-shadow: 0 10px 20px -8px rgba(245, 211, 107, 0.15);
            letter-spacing: 0.3px;
            width: 100%;
            position: relative;
            z-index: 2;
        }
        .btn-invest:hover {
            background: #f9de7c;
            box-shadow: 0 12px 28px -6px rgba(245, 211, 107, 0.25);
            transform: scale(1.01);
        }
        .btn-invest-secondary {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            background: transparent;
            border: 1px solid #3f5a7a;
            color: #cfdef5;
            padding: 0.6rem 0.5rem;
            border-radius: 60px;
            font-weight: 500;
            font-size: 0.85rem;
            transition: all 0.25s;
            cursor: pointer;
            backdrop-filter: blur(2px);
            width: 100%;
        }
        .btn-invest-secondary i {
            color: #f5d36b;
        }
        .btn-invest-secondary:hover {
            background: rgba(245, 211, 107, 0.04);
            border-color: #f5d36b55;
            color: #fff;
        }
        .plan-footer-note {
            text-align: right;
            font-size: 0.65rem;
            color: #4e6a8a;
            margin-top: 0.3rem;
            letter-spacing: 0.2px;
        }
        .action-bar {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
            margin-top: 0.5rem;
            padding-top: 1.8rem;
            border-top: 1px solid rgba(255, 255, 255, 0.03);
        }
        .security-block {
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem 1rem;
        }
        .security-block .shield {
            color: #6fcf97;
            font-size: 1.1rem;
        }
        .security-block .sec-text {
            color: #9ab0d0;
            font-size: 0.85rem;
            font-weight: 400;
            letter-spacing: 0.2px;
        }
        .cms-check-btn {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid #3f5a7a;
            color: #d4e2fc;
            padding: 0.35rem 1.2rem;
            border-radius: 60px;
            font-size: 0.78rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.25s;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }
        .cms-check-btn i {
            font-size: 0.7rem;
            color: #f5d36b;
        }
        .cms-check-btn:hover {
            background: rgba(245, 211, 107, 0.06);
            border-color: #f5d36b;
            color: #f5d36b;
        }
        .footer-note {
            text-align: right;
            margin-top: 1.2rem;
            font-size: 0.75rem;
            color: #6a84a8;
            letter-spacing: 0.2px;
            border-top: 1px solid rgba(255, 255, 255, 0.02);
            padding-top: 1rem;
            font-style: italic;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        .footer-note i {
            color: #6fcf97;
        }

        /* modal */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.75);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            justify-content: center;
            align-items: center;
            z-index: 999;
        }
        .modal-box {
            background: #182338;
            max-width: 560px;
            width: 92%;
            padding: 2.5rem 2rem;
            border-radius: 2.8rem;
            border: 1px solid rgba(245, 211, 107, 0.15);
            box-shadow: 0 40px 80px rgba(0, 0, 0, 0.8);
            text-align: center;
        }
        .modal-box .modal-icon {
            font-size: 2.8rem;
            color: #f5d36b;
            margin-bottom: 0.6rem;
        }
        .modal-box h3 {
            color: #eef3fc;
            font-size: 1.4rem;
            font-weight: 500;
            margin-bottom: 0.4rem;
        }
        .modal-box .sub-text {
            color: #b0cce5;
            font-size: 0.95rem;
            line-height: 1.7;
            margin-bottom: 1.2rem;
        }
        .modal-box .info-description {
            background: rgba(0, 0, 0, 0.25);
            padding: 1.2rem 1.5rem;
            border-radius: 1.5rem;
            border-left: 3px solid #f5d36b;
            margin: 0.8rem 0 1.5rem;
            color: #cfdef5;
            font-size: 0.92rem;
            line-height: 1.8;
            text-align: left;
        }
        .modal-box .info-description i {
            color: #f5d36b;
            margin-right: 0.5rem;
        }
        .copy-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(0, 0, 0, 0.25);
            padding: 0.5rem 1rem 0.5rem 1.5rem;
            border-radius: 60px;
            margin: 0.4rem auto 0.8rem;
            max-width: 95%;
            border: 1px solid rgba(255, 255, 255, 0.03);
        }
        .copy-row span {
            color: #eef3fc;
            font-size: 0.9rem;
            word-break: break-all;
            text-align: left;
            flex: 1;
        }
        .copy-btn {
            background: transparent;
            border: none;
            color: #f5d36b;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.2s;
            padding: 0.3rem 0.6rem;
            border-radius: 40px;
        }
        .copy-btn:hover {
            background: rgba(245, 211, 107, 0.08);
            color: #fff;
        }
        .copy-btn.copied {
            color: #6fcf97;
        }
        .modal-box .btn-close-modal {
            background: #2f405f;
            border: none;
            padding: 0.6rem 2.2rem;
            border-radius: 60px;
            color: white;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 0.5rem;
            font-size: 0.9rem;
            display: inline-block;
        }
        .modal-box .btn-close-modal:hover {
            background: #3f5175;
        }

        @media (max-width: 900px) {
            .card {
                padding: 2rem 1.5rem;
                border-radius: 2.5rem;
            }
            .plans-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 1.5rem;
            }
            .action-bar {
                flex-direction: column;
                align-items: stretch;
            }
            .security-block {
                justify-content: center;
            }
            .trust-actions {
                width: 100%;
                justify-content: flex-start;
            }
        }
        @media (max-width: 650px) {
            body {
                padding: 1rem 0.6rem;
            }
            .card {
                padding: 1.5rem 1rem;
                border-radius: 2rem;
            }
            .plans-grid {
                grid-template-columns: 1fr;
                gap: 1.8rem;
            }
            .sub-head {
                flex-direction: column;
                align-items: start;
                gap: 0.8rem;
            }
            .step-indicators {
                width: 100%;
                justify-content: space-between;
            }
            .trust-bar {
                flex-direction: column;
                align-items: start;
                gap: 0.8rem;
            }
            .footer-note {
                justify-content: center;
                text-align: center;
            }
            .modal-box {
                padding: 2rem 1.2rem;
            }
        }
    </style>
</head>
<body>
    <div class="card">

        <!-- Trust bar with clickable logo and info button -->
        <div class="trust-bar">
            <div class="brand" id="brandLogo">
                <div class="logo-arrows">
                    <i class="fas fa-arrow-up"></i>
                    <i class="fas fa-arrow-down"></i>
                </div>
                <h1>Bitelity</h1>
                <span style="color:#6a84a8; font-weight:300; margin-left:0.2rem; font-size:0.9rem;">·</span>
                <span style="color:#b8cceb; font-weight:400; font-size:0.85rem; letter-spacing:0.2px;">One Time Reserved Price Trades</span>
            </div>
            <div class="trust-actions">
                <button class="info-btn" id="infoBtn"><i class="fas fa-info-circle"></i> How it works</button>
                <div class="trust-badge">
                    <i class="fas fa-shield-alt"></i>
                    <span>Protected &amp; Verified</span>
                    <span class="badge-dot"></span>
                </div>
            </div>
        </div>

        <!-- sub-head -->
        <div class="sub-head">
            <h2><i class="fas fa-lock"></i> Protected by automatic stop-loss 0.7–2% per trade</h2>
            <div class="step-indicators">
                <span><span class="num">1</span></span>
                <span><span class="num">2</span></span>
                <span><span class="num">3</span></span>
                <span style="color:#b0c4e6; font-weight:300; margin-left:0.2rem;">Select tier</span>
            </div>
        </div>

        <!-- plans grid -->
        <div class="plans-grid">

            <!-- BASIC -->
            <div class="plan">
                <div class="plan-header">
                    <span class="plan-name">Basic Account</span>
                    <span class="plan-price">€3,000</span>
                </div>
                <div class="plan-ai">
                    <i class="fas fa-robot"></i>
                    <span>TrendSpider AI</span>
                </div>
                <ul class="plan-features">
                    <li><i class="fas fa-check"></i> Forex Trading + Leverage 1:1</li>
                    <li><i class="fas fa-check"></i> Duration: 3-5 days</li>
                    <li><i class="fas fa-check"></i> Estimated Profit €1,040</li>
                    <li><i class="fas fa-check"></i> Auto Withdrawal €200–300</li>
                </ul>
                <div class="btn-group">
                    <button class="btn-invest" data-plan="Basic"><i class="fas fa-arrow-right"></i> Invest Basic</button>
                    <button class="btn-invest-secondary" data-plan="Basic" data-ai="true"><i class="fas fa-robot"></i> Learn about TrendSpider AI</button>
                </div>
                <div class="plan-footer-note">Secure portal</div>
            </div>

            <!-- STANDART -->
            <div class="plan">
                <div class="plan-header">
                    <span class="plan-name">Standart Account</span>
                    <span class="plan-price">€5,000</span>
                </div>
                <div class="plan-ai">
                    <i class="fas fa-brain"></i>
                    <span>Trade Ideas (Holly AI)</span>
                </div>
                <ul class="plan-features">
                    <li><i class="fas fa-check"></i> Forex + Stocks (Leverage 1:2)</li>
                    <li><i class="fas fa-check"></i> Duration: 3-5 days</li>
                    <li><i class="fas fa-check"></i> Estimated Profit €2,280</li>
                    <li><i class="fas fa-check"></i> Auto Withdrawal €300–400</li>
                </ul>
                <div class="btn-group">
                    <button class="btn-invest" data-plan="Standart"><i class="fas fa-arrow-right"></i> Invest Standart</button>
                    <button class="btn-invest-secondary" data-plan="Standart" data-ai="true"><i class="fas fa-robot"></i> Learn about Trade Ideas (Holly AI)</button>
                </div>
                <div class="plan-footer-note">Secure portal</div>
            </div>

            <!-- ADVANCED -->
            <div class="plan">
                <div class="plan-header">
                    <span class="plan-name">Advanced Account</span>
                    <span class="plan-price">€10,000</span>
                </div>
                <div class="plan-ai">
                    <i class="fas fa-microchip"></i>
                    <span>Tickeron AI</span>
                </div>
                <ul class="plan-features">
                    <li><i class="fas fa-check"></i> Forex, Crypto, Stocks</li>
                    <li><i class="fas fa-check"></i> Duration: 3 days</li>
                    <li><i class="fas fa-check"></i> Estimated Profit €5,490</li>
                    <li><i class="fas fa-check"></i> Auto Withdrawal €700–1,000</li>
                </ul>
                <div class="btn-group">
                    <button class="btn-invest" data-plan="Advanced"><i class="fas fa-arrow-right"></i> Invest Advanced</button>
                    <button class="btn-invest-secondary" data-plan="Advanced" data-ai="true"><i class="fas fa-robot"></i> Learn about Tickeron AI</button>
                </div>
                <div class="plan-footer-note">Secure portal</div>
            </div>
        </div>

        <!-- action bar - now only security info -->
        <div class="action-bar">
            <div class="security-block">
                <i class="fas fa-shield-alt shield"></i>
                <span class="sec-text">All investments are protected by Crypto Market Security Commissions</span>
                <button class="cms-check-btn" id="cmsCheckBtn"><i class="fas fa-external-link-alt"></i> Click here to check</button>
            </div>
        </div>

        <!-- footer -->
        <div class="footer-note">
            <i class="fas fa-circle-check"></i> You don't have to invest the full amount — you may use your current account balance and add the difference only.
        </div>
    </div>

    <!-- Modal overlay -->
    <div class="modal-overlay" id="modalOverlay">
        <div class="modal-box">
            <div class="modal-icon" id="modalIcon"><i class="fas fa-envelope"></i></div>
            <h3 id="modalTitle">Deposit Details</h3>
            <p class="sub-text" id="modalSubText">
                To get deposit details, please send an empty email to your account manager with subject:
            </p>
            <!-- subject row -->
            <div class="copy-row" id="subjectCopyRow">
                <span id="modalSubjectDisplay">RPT Basic</span>
                <button class="copy-btn" id="copySubjectBtn" title="Copy subject"><i class="fas fa-copy"></i></button>
            </div>
            <!-- email row -->
            <div class="copy-row" id="emailCopyRow">
                <span id="modalEmailDisplay">alexanderb@bitelity.info</span>
                <button class="copy-btn" id="copyEmailBtn" title="Copy email"><i class="fas fa-copy"></i></button>
            </div>
            <!-- Info Description (for "How it works" button) -->
            <div class="info-description" id="infoDescription" style="display:none;">
                <i class="fas fa-lightbulb"></i>
                <span id="infoDescriptionText"></span>
            </div>
            <!-- AI Description (for secondary buttons) -->
            <div class="info-description" id="aiDescription" style="display:none;">
                <i class="fas fa-robot"></i>
                <span id="aiDescriptionText"></span>
            </div>
            <button class="btn-close-modal" id="closeModalBtn">Close</button>
        </div>
    </div>

    <script>
        (function() {
            const modalOverlay = document.getElementById('modalOverlay');
            const modalSubjectDisplay = document.getElementById('modalSubjectDisplay');
            const modalEmailDisplay = document.getElementById('modalEmailDisplay');
            const modalTitle = document.getElementById('modalTitle');
            const modalSubText = document.getElementById('modalSubText');
            const modalIcon = document.getElementById('modalIcon');
            const infoDescription = document.getElementById('infoDescription');
            const infoDescriptionText = document.getElementById('infoDescriptionText');
            const aiDescription = document.getElementById('aiDescription');
            const aiDescriptionText = document.getElementById('aiDescriptionText');
            const closeBtn = document.getElementById('closeModalBtn');
            const copyEmailBtn = document.getElementById('copyEmailBtn');
            const copySubjectBtn = document.getElementById('copySubjectBtn');
            const cmsCheckBtn = document.getElementById('cmsCheckBtn');
            const infoBtn = document.getElementById('infoBtn');
            const brandLogo = document.getElementById('brandLogo');

            const EMAIL = 'alexanderb@bitelity.info';

            // AI descriptions
            const aiDescriptions = {
                Basic: 'TrendSpider: Focuses heavily on automated technical analysis. Its power lies in its ability to automatically detect chart patterns and trendlines across thousands of assets, something that would take a human analyst an immense amount of time. It uses AI to simplify and accelerate the strategy-testing process.',
                Standart: 'Trade Ideas: Known for its real-time AI-powered "Holly" engine. It constantly scans the market, backtests dozens of strategies overnight, and presents the highest probability setups to the user at the start of the trading day. Its power is in its proactive idea generation.',
                Advanced: 'Tickeron: Uses AI to provide specific trade ideas and predictions based on pattern recognition. It offers AI-powered "Robo-Advisor" predictions for stocks, ETFs, forex, and crypto, giving clear entry/exit prices and confidence levels. Its power is in its specificity and breadth of coverage.'
            };

            // AI tool names for headings
            const aiToolNames = {
                Basic: 'TrendSpider AI',
                Standart: 'Trade Ideas (Holly AI)',
                Advanced: 'Tickeron AI'
            };

            // Professional "How it works" text
            const infoText = 'Upon selecting an investment tier, your account will be managed by a dedicated AI bot for a period of 3 to 5 days. Each bot is specifically calibrated to the selected offer and operates with strict risk controls, including automatic stop-loss mechanisms. Your capital is additionally safeguarded through insurance provided by the Crypto Market Security Commissions. This one-time trading opportunity is designed for new investors, helping to build a strong foundation for consistent and stable returns in the future.';

            function showModal(planType, mode) {
                let subject = '';
                let planDisplay = '';
                if (planType === 'Basic') {
                    subject = 'RPT Basic';
                    planDisplay = 'Basic';
                } else if (planType === 'Standart') {
                    subject = 'RPT Standart';
                    planDisplay = 'Standart';
                } else if (planType === 'Advanced') {
                    subject = 'RPT Advanced';
                    planDisplay = 'Advanced';
                } else {
                    subject = 'RPT Basic';
                    planDisplay = 'Basic';
                }

                modalSubjectDisplay.textContent = subject;
                modalEmailDisplay.textContent = EMAIL;

                // Hide all special sections first
                infoDescription.style.display = 'none';
                aiDescription.style.display = 'none';
                document.getElementById('subjectCopyRow').style.display = 'flex';
                document.getElementById('emailCopyRow').style.display = 'flex';

                if (mode === 'info') {
                    // "How it works" mode
                    modalTitle.textContent = 'How It Works';
                    modalSubText.textContent = '';
                    modalIcon.innerHTML = '<i class="fas fa-info-circle"></i>';
                    infoDescription.style.display = 'block';
                    infoDescriptionText.textContent = infoText;
                    document.getElementById('subjectCopyRow').style.display = 'none';
                    document.getElementById('emailCopyRow').style.display = 'none';
                } else if (mode === 'ai') {
                    // AI description mode (secondary buttons) - use AI tool name in heading
                    const toolName = aiToolNames[planDisplay] || 'AI Tool';
                    modalTitle.textContent = toolName;
                    modalSubText.textContent = 'Learn about the AI technology powering your investment:';
                    modalIcon.innerHTML = '<i class="fas fa-robot"></i>';
                    aiDescription.style.display = 'block';
                    aiDescriptionText.textContent = aiDescriptions[planDisplay] || aiDescriptions.Basic;
                    document.getElementById('subjectCopyRow').style.display = 'none';
                    document.getElementById('emailCopyRow').style.display = 'none';
                } else {
                    // Deposit details mode (yellow buttons)
                    modalTitle.textContent = 'Deposit Details — ' + planDisplay;
                    modalSubText.textContent = 'To get deposit details, please send an empty email to your account manager with subject:';
                    modalIcon.innerHTML = '<i class="fas fa-envelope"></i>';
                    document.getElementById('subjectCopyRow').style.display = 'flex';
                    document.getElementById('emailCopyRow').style.display = 'flex';
                }

                modalOverlay.style.display = 'flex';
                copyEmailBtn.innerHTML = '<i class="fas fa-copy"></i>';
                copyEmailBtn.classList.remove('copied');
                copySubjectBtn.innerHTML = '<i class="fas fa-copy"></i>';
                copySubjectBtn.classList.remove('copied');
            }

            function closeModal() {
                modalOverlay.style.display = 'none';
            }

            function copyText(text, buttonElement) {
                const fallback = (t, btn) => {
                    const ta = document.createElement('textarea');
                    ta.value = t;
                    document.body.appendChild(ta);
                    ta.select();
                    try {
                        document.execCommand('copy');
                        btn.innerHTML = '<i class="fas fa-check"></i>';
                        btn.classList.add('copied');
                        setTimeout(() => {
                            btn.innerHTML = '<i class="fas fa-copy"></i>';
                            btn.classList.remove('copied');
                        }, 2000);
                    } catch (e) {
                        alert('Could not copy. Please select the text manually.');
                    }
                    document.body.removeChild(ta);
                };
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(text).then(() => {
                        buttonElement.innerHTML = '<i class="fas fa-check"></i>';
                        buttonElement.classList.add('copied');
                        setTimeout(() => {
                            buttonElement.innerHTML = '<i class="fas fa-copy"></i>';
                            buttonElement.classList.remove('copied');
                        }, 2000);
                    }).catch(() => fallback(text, buttonElement));
                } else {
                    fallback(text, buttonElement);
                }
            }

            copyEmailBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                copyText(modalEmailDisplay.textContent.trim(), this);
            });

            copySubjectBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                copyText(modalSubjectDisplay.textContent.trim(), this);
            });

            // Brand logo click → redirect
            brandLogo.addEventListener('click', function() {
                window.open('https://webtrader.bite-lity.net/', '_blank');
            });

            // Info button → show info modal
            infoBtn.addEventListener('click', function() {
                showModal('Basic', 'info');
            });

            // Main yellow buttons (in the plan cards) → deposit details only
            document.querySelectorAll('.btn-invest').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const plan = this.getAttribute('data-plan');
                    showModal(plan || 'Basic', 'deposit');
                });
            });

            // Secondary buttons (with data-ai="true") → show AI description
            document.querySelectorAll('.btn-invest-secondary[data-ai="true"]').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const plan = this.getAttribute('data-plan');
                    showModal(plan || 'Basic', 'ai');
                });
            });

            modalOverlay.addEventListener('click', function(e) {
                if (e.target === modalOverlay) closeModal();
            });
            closeBtn.addEventListener('click', closeModal);
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && modalOverlay.style.display === 'flex') closeModal();
            });

            cmsCheckBtn.addEventListener('click', function() {
                window.open('https://cms-commission.com/our-members/bitelity/', '_blank');
            });
        })();
    </script>

</body>
</html>